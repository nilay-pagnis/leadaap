# Public site URL for embed script examples and absolute links (optional; defaults to request host)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: public form UUID for marketing “Start 5-day pilot” → /f/[id]?source=website&plan=trial
NEXT_PUBLIC_TRIAL_FORM_ID=
# Server-only: public lead submission + public form fetch (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron: Vercel sends Authorization: Bearer <CRON_SECRET> to /api/cron/follow-ups (set in Vercel env + use for manual curl)
CRON_SECRET=generate-a-long-random-string

# Smart WhatsApp alerts (Twilio WhatsApp). From number must be whatsapp:+... (sandbox or approved sender).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Razorpay Payment Links (Dashboard → Payment Links → copy URL for each plan)
NEXT_PUBLIC_RAZORPAY_PAYMENT_LINK_STARTER=https://rzp.io/l/your-starter-link
NEXT_PUBLIC_RAZORPAY_PAYMENT_LINK_GROWTH=https://rzp.io/l/your-growth-link

# Admins: set profiles.role = 'admin' in Supabase (see supabase/admin_roles_and_payments.sql)

# Supabase Auth → URL Configuration: add these to Redirect URLs (password reset)
# http://localhost:3000/auth/callback
# http://localhost:3000/update-password
# https://YOUR_DOMAIN/auth/callback
# https://YOUR_DOMAIN/update-password
